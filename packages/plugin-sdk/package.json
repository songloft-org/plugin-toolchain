{
  "name": "@mimusic/plugin-sdk",
  "version": "0.8.2",
  "description": "TypeScript SDK for MiMusic JS plugin development",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "echo \"no tests yet\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mimusic",
    "plugin",
    "sdk",
    "quickjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mimusic-org/plugin-toolchain.git",
    "directory": "packages/plugin-sdk"
  },
  "homepage": "https://github.com/mimusic-org/plugin-toolchain/tree/main/packages/plugin-sdk#readme",
  "bugs": {
    "url": "https://github.com/mimusic-org/plugin-toolchain/issues"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}

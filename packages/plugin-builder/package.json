{
  "name": "@songloft/plugin-builder",
  "version": "2.2.4",
  "description": "Build tool for Songloft JS plugins (TS/JS → QuickJS-compatible ZIP)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "bin": {
    "songloft-plugin": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "echo \"no tests yet\" && exit 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@songloft/jsc": "workspace:*",
    "esbuild": "^0.25.0",
    "jszip": "^3.10.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@songloft/plugin-sdk": "workspace:^",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "songloft",
    "plugin",
    "builder",
    "quickjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/songloft-org/plugin-toolchain.git",
    "directory": "packages/plugin-builder"
  },
  "homepage": "https://github.com/songloft-org/plugin-toolchain/tree/main/packages/plugin-builder#readme",
  "bugs": {
    "url": "https://github.com/songloft-org/plugin-toolchain/issues"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
